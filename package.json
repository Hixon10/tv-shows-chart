    "e2e": "node scripts/e2e-check.mjs"
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "1.32.0",
    "@duckdb/node-api": "1.5.3-r.2",
    "esbuild": "^0.28.0",
    "puppeteer-core": "^25.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
