{
  "name": "tv-shows-chart",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static site for browsing IMDb / Kinopoisk TV-show rank snapshots with DuckDB-WASM.",
  "scripts": {
    "build": "node scripts/build-site.mjs",
